#!/usr/bin/env bash
set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")" && pwd)"
BROWSE_BIN="${SKILL_DIR}/browse/dist/browse"
FIND_BROWSE_BIN="${SKILL_DIR}/browse/dist/find-browse"
DESIGN_BIN="${SKILL_DIR}/design/dist/design"
GLOBAL_DISCOVER_BIN="${SKILL_DIR}/bin/gstack-global-discover"

if ! command -v bun >/dev/null 2>&1; then
  echo "gstack setup failed: bun is required but was not found in PATH" >&2
  exit 1
fi

needs_rebuild() {
  local output="$1"
  shift

  if [[ ! -x "${output}" ]]; then
    return 0
  fi

  local input
  for input in "$@"; do
    if [[ -e "${input}" && "${input}" -nt "${output}" ]]; then
      return 0
    fi
  done

  return 1
}

newer_source_exists() {
  local source_dir="$1"
  local output="$2"
  [[ -d "${source_dir}" ]] && [[ -n "$(find "${source_dir}" -type f -newer "${output}" -print -quit 2>/dev/null)" ]]
}

ensure_playwright_browser() {
  (
    cd "${SKILL_DIR}"
    bun --eval 'import { chromium } from "playwright"; const browser = await chromium.launch(); await browser.close();'
  ) >/dev/null 2>&1
}

(
  cd "${SKILL_DIR}"
  bun install --frozen-lockfile 2>/dev/null || bun install
)

mkdir -p "${SKILL_DIR}/browse/dist" "${SKILL_DIR}/design/dist"

if needs_rebuild "${BROWSE_BIN}" "${SKILL_DIR}/package.json" "${SKILL_DIR}/bun.lock" || newer_source_exists "${SKILL_DIR}/browse/src" "${BROWSE_BIN}"; then
  echo "Building gstack browse binary..."
  (
    cd "${SKILL_DIR}"
    bun build --compile browse/src/cli.ts --outfile browse/dist/browse
    bun build --compile browse/src/find-browse.ts --outfile browse/dist/find-browse
    bash browse/scripts/build-node-server.sh
    git rev-parse HEAD > browse/dist/.version 2>/dev/null || date -u +%Y%m%d%H%M%S > browse/dist/.version
    chmod +x browse/dist/browse browse/dist/find-browse
  )
fi

if needs_rebuild "${DESIGN_BIN}" "${SKILL_DIR}/package.json" "${SKILL_DIR}/bun.lock" || newer_source_exists "${SKILL_DIR}/design/src" "${DESIGN_BIN}"; then
  echo "Building gstack design binary..."
  (
    cd "${SKILL_DIR}"
    bun build --compile design/src/cli.ts --outfile design/dist/design
    git rev-parse HEAD > design/dist/.version 2>/dev/null || date -u +%Y%m%d%H%M%S > design/dist/.version
    chmod +x design/dist/design
  )
fi

if needs_rebuild "${GLOBAL_DISCOVER_BIN}" "${SKILL_DIR}/bin/gstack-global-discover.ts" "${SKILL_DIR}/package.json" "${SKILL_DIR}/bun.lock"; then
  echo "Building gstack global discovery helper..."
  (
    cd "${SKILL_DIR}"
    bun build --compile bin/gstack-global-discover.ts --outfile bin/gstack-global-discover
    chmod +x bin/gstack-global-discover
  )
fi

if ! ensure_playwright_browser; then
  echo "Installing Playwright Chromium..."
  (
    cd "${SKILL_DIR}"
    bunx playwright install chromium
  )
fi

if ! ensure_playwright_browser; then
  echo "gstack setup failed: Playwright Chromium could not be launched" >&2
  exit 1
fi

echo "gstack ready."
echo "  root: ${SKILL_DIR}"
echo "  browse: ${BROWSE_BIN}"
echo "  design: ${DESIGN_BIN}"
